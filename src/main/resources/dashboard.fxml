<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="750.0" prefWidth="1050.0" xmlns="http://javafx.com/javafx/17.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.app.controller.DashboardController">
    <top>
        <VBox>
            <HBox alignment="CENTER" spacing="40" style="-fx-background-color: #0d1117; -fx-padding: 20;">
                <HBox spacing="15" alignment="CENTER">
                    <VBox alignment="CENTER">
                        <Label text="OCCUPANCY" textFill="#8b949e" style="-fx-font-size: 10px; -fx-font-weight: bold;" />
                        <Label fx:id="lblOccupancy" text="0%" textFill="WHITE" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                </HBox>
                <Separator orientation="VERTICAL" />
                <HBox spacing="15" alignment="CENTER">
                    <VBox alignment="CENTER">
                        <Label text="TOTAL BOOKINGS" textFill="#8b949e" style="-fx-font-size: 10px; -fx-font-weight: bold;" />
                        <Label fx:id="lblTotalBookings" text="0" textFill="WHITE" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                </HBox>
                <Separator orientation="VERTICAL" />
                <HBox spacing="15" alignment="CENTER">
                    <VBox alignment="CENTER">
                        <Label text="EST. REVENUE" textFill="#8b949e" style="-fx-font-size: 10px; -fx-font-weight: bold;" />
                        <Label fx:id="lblTotalRevenue" text="₹0.00" textFill="#238636" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                </HBox>
            </HBox>
            <HBox alignment="CENTER_RIGHT" style="-fx-background-color: #161b22; -fx-padding: 5 30;">
                <Label text="Local Time: " textFill="#8b949e">
                    <font><Font size="14.0" /></font>
                </Label>
                <Label fx:id="lblClock" text="12:00:00" textFill="#58a6ff">
                    <font><Font name="System Bold" size="16.0" /></font>
                </Label>
            </HBox>
        </VBox>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
            <tabs>
                <!-- Room Management Tab -->
                <Tab text="Room Management">
                    <SplitPane dividerPositions="0.25" prefHeight="160.0" prefWidth="200.0">
                        <VBox spacing="20.0" style="-fx-background-color: #161b22;">
                            <padding><Insets bottom="20.0" left="20.0" right="20.0" top="30.0"/></padding>
                            <Label text="Add New Room" textFill="WHITE">
                                <font><Font name="System Bold" size="20.0"/></font>
                            </Label>
                            <Separator />
                            <TextField fx:id="txtRoomNo" promptText="Room Number" />
                            <ComboBox fx:id="cbRoomType" maxWidth="1.7976931348623157E308" promptText="Select Room Type" />
                            <TextField fx:id="txtPrice" promptText="Price per Night (₹)" />
                            <Region VBox.vgrow="ALWAYS" />
                            <Button mnemonicParsing="false" onAction="#addRoom" maxWidth="1.7976931348623157E308" text="Add Room" styleClass="accent" />
                        </VBox>
                        <VBox spacing="10">
                            <padding><Insets bottom="10" left="10" right="10" top="10"/></padding>
                            <TextField fx:id="txtSearchRooms" promptText="🔍 Search by Room Number or Type..." style="-fx-background-radius: 20;" />
                            <TableView fx:id="roomTable" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colRoomNo" prefWidth="120.0" text="Room Number" />
                                    <TableColumn fx:id="colType" prefWidth="180.0" text="Room Type" />
                                    <TableColumn fx:id="colPrice" prefWidth="120.0" text="Price/Night (₹)" />
                                    <TableColumn fx:id="colAvail" prefWidth="150.0" text="Available" />
                                </columns>
                            </TableView>
                        </VBox>
                    </SplitPane>
                </Tab>
                
                <!-- Booking Tab -->
                <Tab text="Bookings &amp; Checkout">
                    <SplitPane dividerPositions="0.25" prefHeight="160.0" prefWidth="200.0">
                        <VBox spacing="15.0" style="-fx-background-color: #161b22;">
                            <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/></padding>
                            <Label text="New Booking" textFill="WHITE">
                                <font><Font name="System Bold" size="20.0"/></font>
                            </Label>
                            <Separator />
                            <TextField fx:id="txtGuestName" promptText="Guest Name" />
                            <TextField fx:id="txtGuestContact" promptText="Contact Number" />
                            <TextField fx:id="txtIdProof" promptText="ID Proof Number" />
                            <ComboBox fx:id="cbAvailableRooms" maxWidth="1.7976931348623157E308" promptText="Select Room" />
                            <DatePicker fx:id="dpCheckIn" maxWidth="1.7976931348623157E308" promptText="Arrival" />
                            <DatePicker fx:id="dpCheckOut" maxWidth="1.7976931348623157E308" promptText="Departure" />
                            <Region VBox.vgrow="ALWAYS" />
                            <Button mnemonicParsing="false" onAction="#bookRoom" maxWidth="1.7976931348623157E308" text="Submit Booking" styleClass="success" />
                        </VBox>
                        <VBox spacing="10">
                            <padding><Insets bottom="10" left="10" right="10" top="10"/></padding>
                            <TextField fx:id="txtSearchBookings" promptText="🔍 Filter by Guest Name or Booking ID..." style="-fx-background-radius: 20;" />
                            <TableView fx:id="bookingTable" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colBookId" prefWidth="120.0" text="Booking ID" />
                                    <TableColumn fx:id="colGuestName" prefWidth="180.0" text="Guest Name" />
                                    <TableColumn fx:id="colBookRoom" prefWidth="120.0" text="Room No" />
                                    <TableColumn fx:id="colCheckedOut" prefWidth="150.0" text="Is Checked Out" />
                                </columns>
                            </TableView>
                            
                            <TitledPane animated="false" collapsible="false" text="Live Invoice Summary">
                                <VBox spacing="10">
                                    <Label fx:id="lblInvoiceDetails" text="Select a booking and click Checkout to generate summary." wrapText="true" minHeight="100"/>
                                    <HBox alignment="CENTER_RIGHT" spacing="10">
                                        <Button fx:id="btnCheckout" text="Perform Checkout" onAction="#checkout" styleClass="danger" />
                                    </HBox>
                                </VBox>
                            </TitledPane>
                        </VBox>
                    </SplitPane>
                </Tab>
            </tabs>
        </TabPane>
    </center>
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #0d1117;" prefHeight="40">
            <padding><Insets left="20" right="20"/></padding>
            <Label fx:id="lblStatus" text="System Ready" textFill="#8b949e" />
            <Region HBox.hgrow="ALWAYS" />
            <Label text="made by Nimay Pant" textFill="#444d56" style="-fx-font-size: 10px; -fx-font-style: italic; -fx-padding: 0 20 0 0;" />
            <Button text="System Backup (.dat)" onAction="#performBackup" styleClass="flat" />
            <Button text="Export System Logs (.csv)" onAction="#exportLogs" styleClass="flat" />
        </HBox>
    </bottom>
</BorderPane>
